{
    "name": "prayer-time-reminder",
    "displayName": "Prayer Time Reminder",
    "description": "Islamic prayer companion with live HH:MM:SS countdown, aesthetic sidebar dashboard, daily Quran verses, and tasbih counter.",
    "version": "1.1.2",
    "publisher": "riflo",
    "icon": "icons/icon.png",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "prayer",
        "islam",
        "ramadan",
        "muslim",
        "sholat",
        "adhan",
        "tasbih",
        "quran"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./extension.js",
    "repository": {
        "type": "git",
        "url": "https://github.com/Rifuroo/prayer-status"
    },
    "license": "MIT",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "prayer-explorer",
                    "title": "Prayer Time",
                    "icon": "icons/icon.png"
                }
            ]
        },
        "views": {
            "prayer-explorer": [
                {
                    "type": "webview",
                    "id": "prayerTime.dashboard",
                    "name": "Dashboard",
                    "icon": "icons/icon.png"
                }
            ]
        },
        "configuration": {
            "title": "Prayer Time Reminder",
            "properties": {
                "prayer.city": {
                    "type": "string",
                    "default": "Malang",
                    "description": "City name for prayer time calculation. Leave empty for auto-detection via IP."
                },
                "prayer.country": {
                    "type": "string",
                    "default": "Indonesia",
                    "description": "Country name for prayer time calculation. Leave empty for auto-detection via IP."
                },
                "prayer.method": {
                    "type": "number",
                    "default": 11,
                    "description": "Prayer time calculation method (see aladhan.com/calculation-methods)"
                },
                "prayer.notifications": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable popup notifications when prayer time arrives"
                },
                "prayer.ramadanMode": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable special Suhoor/Iftar labels and Ramadan greetings"
                },
                "prayer.showHijriDate": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show Hijri date in the status bar"
                },
                "prayer.showSeconds": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show seconds in the countdown timer"
                },
                "prayer.playAdzanSound": {
                    "type": "boolean",
                    "default": true,
                    "description": "Play a notification sound when it's time to pray"
                },
                "prayer.dailyAyatEnabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show a random Quran verse on startup"
                }
            }
        },
        "commands": [
            {
                "command": "prayerTime.showSchedule",
                "title": "Prayer Time: Show Today's Schedule"
            },
            {
                "command": "prayerTime.refresh",
                "title": "Prayer Time: Refresh"
            },
            {
                "command": "prayerTime.toggleRamadanMode",
                "title": "Prayer Time: Toggle Ramadan Mode"
            },
            {
                "command": "prayerTime.incrementTasbih",
                "title": "Prayer Time: Increment Tasbih"
            },
            {
                "command": "prayerTime.resetTasbih",
                "title": "Prayer Time: Reset Tasbih"
            }
        ]
    },
    "dependencies": {
        "axios": "^1.6.0"
    }
}